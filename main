<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flappy Bird - HTML Edition</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: linear-gradient(#81D4FA, #E1F5FE);
            font-family: Arial, sans-serif;
            overflow: hidden;
        }
        #game-container {
            position: relative;
        }
        canvas {
            border: 6px solid #fff;
            box-shadow: 0 0 40px rgba(0, 255, 100, 0.6);
            border-radius: 8px;
        }
        #score {
            position: absolute;
            top: 25px;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            font-size: 58px;
            font-weight: bold;
            text-shadow: 4px 4px 0 #000;
            z-index: 10;
            pointer-events: none;
        }

        /* Menu */
        #menu {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(12px);
            padding: 40px 60px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            z-index: 30;
            border: 5px solid #4CAF50;
            max-width: 340px;
        }
        .title {
            font-size: 52px;
            color: #2E7D32;
            margin: 0 0 8px 0;
        }
        .subtitle {
            font-size: 24px;
            color: #1B5E20;
            margin: 0 0 25px 0;
            font-weight: bold;
        }
        .credit {
            margin-top: 25px;
            font-size: 14px;
            color: #666;
            font-weight: normal;
        }
        button {
            display: block;
            width: 280px;
            margin: 10px auto;
            padding: 15px;
            font-size: 22px;
            font-weight: bold;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        button:hover {
            transform: scale(1.05);
        }
        .super-easy { background: #4CAF50; }
        .easy { background: #8BC34A; }
        .normal { background: #FF9800; }
        .hard { background: #F44336; }
        .extreme { background: #B71C1C; }
    </style>
</head>
<body>
    <div id="game-container">
        <div id="score">0</div>
        <canvas id="game" width="400" height="600"></canvas>

        <!-- Main Menu -->
        <div id="menu">
            <div class="title">Flappy Bird</div>
            <div class="subtitle">HTML Edition</div>
            
            <button class="super-easy" onclick="startSuperEasy()">SUPER EASY MODE</button>
            <button class="easy" onclick="startEasy()">EASY MODE</button>
            <button class="normal" onclick="startNormal()">NORMAL MODE</button>
            <button class="hard" onclick="startHard()">HARD MODE</button>
            <button class="extreme" onclick="startExtreme()">EXTREME MODE</button>

            <div class="credit">Made By Visnouk</div>
        </div>

        <!-- Game Over -->
        <div id="game-over">
            <div style="font-size:48px; margin-bottom:10px;">💥 GAME OVER</div>
            <p id="final-score" style="font-size:32px; margin:15px 0;">Score: 0</p>
            <button onclick="restartGame()" style="background:#FF9800; width:200px;">PLAY AGAIN</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('score');
        const menu = document.getElementById('menu');
        const gameOverScreen = document.getElementById('game-over');
        const finalScoreEl = document.getElementById('final-score');

        let bird = { x: 90, y: 280, velocity: 0, gravity: 0.45, jump: -11.5, size: 30, rotation: 0 };
        let pipes = [];
        let frame = 0;
        let score = 0;
        let gameRunning = false;
        let gameOverFlag = false;
        let bgX = 0;
        let currentMode = 'superEasy';

        function drawBird() {
            ctx.save();
            ctx.translate(bird.x + 15, bird.y + 15);
            ctx.rotate(bird.rotation * Math.PI / 180);
            ctx.fillStyle = '#FFEB3B';
            ctx.beginPath(); ctx.ellipse(0, 0, 18, 16, 0, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#FBC02D';
            ctx.beginPath(); ctx.ellipse(-7, 6, 13, 8, 0.4, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#fff';
            ctx.beginPath(); ctx.arc(10, -6, 7, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#000';
            ctx.beginPath(); ctx.arc(12, -6, 3.5, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#FF5722';
            ctx.beginPath(); ctx.moveTo(18, -1); ctx.lineTo(26, -4); ctx.lineTo(26, 3); ctx.fill();
            ctx.restore();
        }

        function drawPipe(x, topHeight) {
            const w = 68;
            let gap = 172;
            if (currentMode === 'superEasy') gap = 265;
            else if (currentMode === 'easy') gap = 215;
            else if (currentMode === 'normal') gap = 172;
            else if (currentMode === 'hard') gap = 145;
            else if (currentMode === 'extreme') gap = 125;

            ctx.fillStyle = '#66BB6A';
            ctx.fillRect(x, 0, w, topHeight);
            ctx.fillStyle = '#2E7D32';
            ctx.fillRect(x, 0, w, topHeight);
            ctx.fillStyle = '#A5D6A7';
            ctx.fillRect(x + 6, topHeight - 18, w - 12, 22);

            const bottomY = topHeight + gap;
            ctx.fillStyle = '#66BB6A';
            ctx.fillRect(x, bottomY, w, canvas.height - bottomY);
            ctx.fillStyle = '#2E7D32';
            ctx.fillRect(x, bottomY, w, canvas.height - bottomY);
            ctx.fillStyle = '#A5D6A7';
            ctx.fillRect(x + 6, bottomY, w - 12, 22);
        }

        function update() {
            if (!gameRunning || gameOverFlag) return;

            bird.velocity += bird.gravity;
            bird.y += bird.velocity;
            bird.rotation = Math.max(Math.min(bird.velocity * 4, 80), -30);

            if (bird.y + bird.size > 545 || bird.y < -5) {
                endGame();
                return;
            }

            for (let i = 0; i < pipes.length; i++) {
                let p = pipes[i];
                let speed = 2.2;
                if (currentMode === 'superEasy') speed = 1.75;
                else if (currentMode === 'easy') speed = 1.95;
                else if (currentMode === 'hard') speed = 2.5;
                else if (currentMode === 'extreme') speed = 2.85;
                p.x -= speed;

                if (!p.scored && p.x + 68 < bird.x) {
                    score++;
                    scoreEl.textContent = score;
                    p.scored = true;
                }

                if (
                    bird.x + bird.size - 8 > p.x && bird.x + 8 < p.x + 68 &&
                    (bird.y + 8 < p.topHeight || bird.y + bird.size - 8 > p.bottomY)
                ) {
                    endGame();
                    return;
                }

                if (p.x < -100) pipes.splice(i, 1);
            }

            let spawnRate = 55;
            if (currentMode === 'superEasy') spawnRate = 72;
            else if (currentMode === 'easy') spawnRate = 65;
            else if (currentMode === 'hard') spawnRate = 48;
            else if (currentMode === 'extreme') spawnRate = 42;

            if (frame % spawnRate === 0) {
                let gap = 172, minH = 55, maxH = 155;
                if (currentMode === 'superEasy') { minH = 12; maxH = 45; gap = 265; }
                else if (currentMode === 'easy') { minH = 20; maxH = 75; gap = 215; }
                else if (currentMode === 'normal') { minH = 55; maxH = 155; gap = 172; }
                else if (currentMode === 'hard') { minH = 70; maxH = 175; gap = 145; }
                else if (currentMode === 'extreme') { minH = 85; maxH = 185; gap = 125; }

                const topHeight = Math.floor(Math.random() * (maxH - minH + 1)) + minH;
                pipes.push({ x: canvas.width + 30, topHeight, bottomY: topHeight + gap, scored: false });
            }

            bgX -= 1.3;
            if (bgX <= -canvas.width) bgX = 0;
            frame++;
        }

        function drawBackground() {
            const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
            grad.addColorStop(0, "#81D4FA");
            grad.addColorStop(1, "#E1F5FE");
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            ctx.fillStyle = "rgba(255,255,255,0.9)";
            ctx.beginPath(); ctx.ellipse(bgX + 80, 120, 50, 28, 0, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(bgX + 125, 105, 38, 26, 0, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(bgX + 350, 170, 58, 32, 0, 0, Math.PI*2); ctx.fill();

            ctx.fillStyle = "#8BC34A";
            ctx.fillRect(0, 550, canvas.width, 50);
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawBackground();
            pipes.forEach(p => drawPipe(p.x, p.topHeight));
            drawBird();
        }

        function gameLoop() {
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }

        function flap() {
            if (gameRunning && !gameOverFlag) bird.velocity = bird.jump;
        }

        function startSuperEasy() { currentMode = 'superEasy'; startGame(); }
        function startEasy() { currentMode = 'easy'; startGame(); }
        function startNormal() { currentMode = 'normal'; startGame(); }
        function startHard() { currentMode = 'hard'; startGame(); }
        function startExtreme() { currentMode = 'extreme'; startGame(); }

        function startGame() {
            menu.style.display = 'none';
            resetGame();
            gameRunning = true;
            gameOverFlag = false;
        }

        function endGame() {
            gameRunning = false;
            gameOverFlag = true;
            finalScoreEl.textContent = `Score: ${score}`;
            gameOverScreen.style.display = 'block';
        }

        function restartGame() {
            gameOverScreen.style.display = 'none';
            menu.style.display = 'block';
            gameRunning = false;
            gameOverFlag = false;
        }

        function resetGame() {
            bird.y = 280;
            bird.velocity = 0;
            bird.rotation = 0;
            pipes = [];
            score = 0;
            frame = 0;
            scoreEl.textContent = '0';
        }

        // Controls
        document.addEventListener('keydown', e => {
            if (e.key === ' ') {
                e.preventDefault();
                if (gameOverFlag) restartGame();
                else if (gameRunning) flap();
            }
        });

        canvas.addEventListener('mousedown', () => {
            if (gameOverFlag) restartGame();
            else if (gameRunning) flap();
        });

        canvas.addEventListener('touchstart', e => {
            e.preventDefault();
            if (gameOverFlag) restartGame();
            else if (gameRunning) flap();
        });

        window.onload = () => {
            gameLoop();
        };
    </script>
</body>
</html>
